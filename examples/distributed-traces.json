{
  "version": "1.0",
  "pipelines": [
    {
      "name": "otlp-traces-to-jaeger",
      "signal": "traces",
      "receivers": [
        {
          "type": "otlp",
          "protocol": "grpc",
          "endpoint": "0.0.0.0:4317",
          "settings": {
            "max_recv_msg_size_mib": 16,
            "keepalive": {
              "server_parameters": {
                "max_connection_age": "300s"
              }
            }
          }
        }
      ],
      "processors": [
        {
          "type": "batch",
          "settings": {
            "send_batch_size": 512,
            "send_batch_max_size": 1024,
            "timeout": "2s"
          }
        }
      ],
      "exporters": [
        {
          "type": "otlp",
          "endpoint": "jaeger-collector.tracing.svc:4317",
          "settings": {
            "protocol": "grpc",
            "tls": {
              "insecure": true
            },
            "retry_on_failure": {
              "enabled": true,
              "initial_interval": "5s",
              "max_interval": "30s",
              "max_elapsed_time": "120s"
            }
          }
        }
      ]
    }
  ]
}

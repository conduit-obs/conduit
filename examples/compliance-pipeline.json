{
  "version": "1.0",
  "pipelines": [
    {
      "name": "compliance-data-sanitization",
      "signal": "logs",
      "receivers": [
        {
          "type": "otlp",
          "protocol": "grpc",
          "endpoint": "0.0.0.0:4317"
        }
      ],
      "processors": [
        {
          "type": "transform",
          "settings": {
            "error_mode": "ignore",
            "log_statements": [
              {
                "context": "log",
                "statements": [
                  "replace_pattern(body, \"\\b\\d{3}-\\d{2}-\\d{4}\\b\", \"[SSN_REDACTED]\")",
                  "replace_pattern(body, \"\\b(?:4[0-9]{12}(?:[0-9]{3})?|5[1-5][0-9]{14}|3[47][0-9]{13})\\b\", \"[CARD_REDACTED]\")",
                  "replace_pattern(body, \"\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b\", \"[EMAIL_REDACTED]\")",
                  "replace_pattern(body, \"\\b\\d{3}[-.\\s]?\\d{3}[-.\\s]?\\d{4}\\b\", \"[PHONE_REDACTED]\")"
                ]
              }
            ]
          }
        },
        {
          "type": "attributes",
          "settings": {
            "actions": [
              {
                "key": "user.password",
                "action": "delete"
              },
              {
                "key": "user.secret",
                "action": "delete"
              },
              {
                "key": "db.connection_string",
                "action": "delete"
              },
              {
                "key": "http.request.header.authorization",
                "action": "delete"
              },
              {
                "key": "http.request.header.cookie",
                "action": "delete"
              },
              {
                "key": "compliance.processed",
                "value": true,
                "action": "upsert"
              },
              {
                "key": "compliance.policy_version",
                "value": "2.1",
                "action": "upsert"
              }
            ]
          }
        },
        {
          "type": "batch",
          "settings": {
            "send_batch_size": 512,
            "timeout": "5s"
          }
        }
      ],
      "exporters": [
        {
          "type": "otlp",
          "endpoint": "compliance-collector.security.svc:4317",
          "settings": {
            "protocol": "grpc",
            "tls": {
              "insecure": false,
              "cert_file": "/etc/tls/compliance-client.crt",
              "key_file": "/etc/tls/compliance-client.key",
              "ca_file": "/etc/tls/ca.crt"
            },
            "retry_on_failure": {
              "enabled": true,
              "initial_interval": "1s",
              "max_interval": "30s",
              "max_elapsed_time": "300s"
            }
          }
        }
      ]
    }
  ]
}

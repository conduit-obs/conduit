{
  "version": "1.0",
  "pipelines": [
    {
      "name": "prometheus-to-otlp",
      "signal": "metrics",
      "receivers": [
        {
          "type": "prometheus",
          "protocol": "http",
          "endpoint": "0.0.0.0:9090",
          "settings": {
            "scrape_interval": "15s",
            "scrape_configs": [
              {
                "job_name": "app-metrics",
                "static_targets": ["app-server:8080", "app-server:8081"]
              }
            ]
          }
        }
      ],
      "processors": [
        {
          "type": "batch",
          "settings": {
            "send_batch_size": 1024,
            "timeout": "5s"
          }
        }
      ],
      "exporters": [
        {
          "type": "otlp",
          "endpoint": "otel-collector.monitoring.svc:4317",
          "settings": {
            "protocol": "grpc",
            "compression": "gzip",
            "tls": {
              "insecure": false,
              "cert_file": "/etc/tls/client.crt",
              "key_file": "/etc/tls/client.key"
            }
          }
        }
      ]
    }
  ]
}

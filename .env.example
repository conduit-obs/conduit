# Conduit Local Development Environment Configuration
# Copy to .env and customize as needed.

# PostgreSQL
POSTGRES_DB=conduit
POSTGRES_USER=conduit
POSTGRES_PASSWORD=conduit-dev
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Conduit API
API_PORT=8080
OPAMP_PORT=4320
LOG_LEVEL=info

# JWT
JWT_ISSUER=conduit
JWT_AUDIENCE=conduit-api

# Auth0 (optional — leave empty for local email/password auth)
# CONDUIT_AUTH0_DOMAIN=your-tenant.us.auth0.com
# CONDUIT_AUTH0_CLIENT_ID=your-client-id
# CONDUIT_AUTH0_AUDIENCE=https://api.conduit.local
# CONDUIT_AUTH0_REDIRECT_URI=http://localhost:3000/auth/callback

# Mock Collectors
MOCK_AGENT_COUNT=10
MOCK_HEARTBEAT_INTERVAL=15
